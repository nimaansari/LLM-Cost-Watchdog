# Cost Watchdog Environment Variables
# Copy this file to .env and fill in your values

# Optional: API keys for direct provider access
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=

# Optional: Budget settings
# DEFAULT_BUDGET=5.00
# BUDGET_PRIORITY=medium

# Optional: Notification settings
# SLACK_WEBHOOK_URL=
# EMAIL_NOTIFICATIONS=false
